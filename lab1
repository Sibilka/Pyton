print("Перевод десятичного числа в систему счисления (2-9)")

# Ввод числа (можно отрицательное)
while True:
    try:
        num = int(input("Введите целое число: "))
        break 
    except ValueError:
        print("Ошибка: нужно ввести целое число")

# Ввод основания
while True:
    try:
        base = int(input("Введите основание от 2 до 9: "))
        if 2 <= base <= 9:
            break
        print("Ошибка: основание должно быть от 2 до 9")
    except ValueError:
        print("Ошибка: нужно ввести целое число")

# Запоминаем знак, работаем с абсолютной величиной
if num < 0:
    sign = "-"
    n = -num
else:
    sign = ""
    n = num

# Перевод положительного числа n (или нуля)
if n == 0:
    result = "0"
else:
    digits = []
    while n > 0:
        digits.append(str(n % base))   # остаток
        n //= base                     # деление нацело
    result = "".join(reversed(digits)) # переворачиваем и склеиваем

# Добавляем знак минус, если нужно
final = sign + result

# Вывод
print(f"Результат: число {num} в системе с основанием {base} = {final}")
